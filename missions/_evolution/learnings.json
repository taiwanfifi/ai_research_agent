      "category": "training",
      "pattern": "GPT-2: set tokenizer.pad_token = tokenizer.eos_token AND model.config.pad_token_id. DistilBERT: use \"distilbert-base-uncased\". DistilGPT-2: use \"distilgpt2\".",
