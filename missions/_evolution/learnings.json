      "id": "L02",
      "type": "pitfall",
      "category": "environment",
      "pattern": "PEFT/LoRA fine-tuning MUST use CPU on Apple Silicon. MPS crashes. Set os.environ[\"CUDA_VISIBLE_DEVICES\"]=\"\" BEFORE torch import.",
